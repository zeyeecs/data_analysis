# 本地开发（任选其一）：
# 1. 仓库根目录已有 database.env 时，web 会自动读取，无需本文件
# 2. 或执行：npm run env:sync  （从 ../database.env 生成 .env.local）
# 3. 或手动复制本文件为 .env.local 并填写 DATABASE_URL
#
# Vercel 部署：在项目环境变量中配置 DATABASE_URL（须为 Neon pooler 连接串）
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
