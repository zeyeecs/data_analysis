# 一次性全表格式化（首次部署或大规模修复后手动触发）
#   sudo systemctl start sjkx-format-full.service
# 全表 + LLM 可能耗时数小时；建议在服务器后台跑，勿在本地执行。

[Unit]
Description=sjkx full product field format (F/R/V all rows)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=deploy
Group=deploy
WorkingDirectory=/opt/sjkx
Environment=PATH=/opt/sjkx/.venv/bin:/usr/bin:/bin
EnvironmentFile=-/opt/sjkx/.env
Environment=SJKX_FORMAT_MODE=full
ExecStart=/opt/sjkx/scripts/run_format_job.sh

UnsetEnvironment=DATABASE_URL

[Install]
WantedBy=multi-user.target
