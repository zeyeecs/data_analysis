# 飞书开放平台应用凭证（复制为 .env 后填写）
FEISHU_APP_ID=
FEISHU_APP_SECRET=

FEISHU_API_BASE=https://open.feishu.cn/open-apis

FEISHU_ROOT_FOLDER_TOKEN=
FEISHU_ROOT_FOLDER_URL=

# 三家竞品店已售数据目录（非自家店铺）
FEISHU_FOLDER_F=
FEISHU_FOLDER_R=
FEISHU_FOLDER_V=
FEISHU_FOLDER_F_SOURCE=
FEISHU_FOLDER_R_SOURCE=
FEISHU_FOLDER_V_SOURCE=

FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_URL=

FEISHU_STORE_CONTENT=true
FEISHU_MAX_DB_FILE_BYTES=104857600
FEISHU_PARSE_XLSX_ROWS=false

# 商品字段 LLM 语义解析（可选；规则引擎为默认）
# PRODUCT_FORMAT_USE_LLM=true
#
# --- DeepSeek（推荐，OpenAI 兼容）---
# 密钥: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_JSON_MODE=true
# DEEPSEEK_TIMEOUT_SEC=60
#
# --- 或其它 OpenAI 兼容云端 ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# SEMANTIC_PARSE_CACHE_PATH=data/semantic_parse_cache.db

# 默认保留 xlsx 图片链接；设为 true 则导入时清空图片列
IMPORT_EMPTY_IMAGES=false
# 每个飞书目录内并行处理的 xlsx 数量（建议 4~8，过大可能触发飞书限流）
IMPORT_WORKERS=4

# Cloudflare R2（默认导入会将图片下载并上传到 R2，库中写入公开地址）
R2_MIRROR_IMAGES=true
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# 桶的公开访问域名或自定义域，无末尾斜杠，例如 https://img.example.com
R2_PUBLIC_BASE_URL=
R2_KEY_PREFIX=sjkx

# 图片镜像：并行下载线程数、重试（Shopify CDN 偶发 SSL/超时）
IMAGE_MIRROR_WORKERS=8
IMAGE_MIRROR_DOWNLOAD_RETRIES=5
IMAGE_MIRROR_DOWNLOAD_TIMEOUT=90
IMAGE_MIRROR_HTTP_RETRIES=3
